DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/clairvoyance
LOG_LEVEL=INFO

# Required for real odds/props in data.json — get a key at https://the-odds-api.com
# Without a valid key, clairvoyance_update.py still runs (scrapers all work),
# but best_bets/EV calculations come back empty since there's no market to
# compare against — a good sanity check for backend-only test runs, but never
# push that output as if it were real.
ODDS_API_KEY=

# Optional — set to a Discord webhook URL (Server Settings > Integrations >
# Webhooks) to get a same-day ping when a scrape fails, a source that should
# never be empty comes back empty, or a post-push deploy verification fails.
# Leave blank to keep the old silent-on-CI behavior (local macOS notification
# only).
DISCORD_WEBHOOK_URL=
